ông cần vì cấu trúc là list of dictionaries ở cấp gốc\n","    # meta: Các cột muốn giữ lại từ cấp gốc\n","    # record_prefix: Tiền tố cho các cột được làm phẳng (không cần trong trường hợp này)\n","\n","    df = json_normalize(\n","        data,\n","        meta=[\n","            'head_entity_id', 'head_entity_text', 'head_entity_type',\n","            'tail_entity_id', 'tail_entity_text', 'tail_entity_type',\n","            'relation_type', 'confidence', 'source_type', 'relation_id'\n","        ],\n","        record_path=['evidence'],\n","        sep='_' # Tách tên cột con bằng dấu '_' (vd: evidence_text, evidence_source_qa_id)\n","    )\n","\n","    # Do cấu trúc json_normalize trong trường hợp này phức tạp, cách đơn giản hơn là\n","    # làm phẳng cột 'evidence' sau đó hợp nhất (merge) với các cột gốc.\n","\n","    # 3.1. Chuyển JSON gốc thành DataFrame\n","    df_main = pd.DataFrame(data)\n","\n","    # 3.2. Làm phẳng cột 'evidence'\n","    df_evidence = json_normalize(df_main['evidence'])\n","\n","    # 3.3. Hợp nhất (Concatenate) các cột đã làm phẳng với các cột gốc,\n","    # sau đó bỏ cột 'evidence' gốc\n","    df_final = pd.concat([df_main.drop('evidence', axis=1), df_evidence], axis=1)\n","\n","    # 3.4. Đổi tên cột cho rõ ràng (tuỳ chọn)\n","    df_final = df_final.rename(columns={\n","        'text': 'evidence_text',\n","        'source_qa_id': 'evidence_source_qa_id'\n","    })\n","\n","    print(f\"Tổng số hàng sau khi làm phẳng: {len(df_final)}\")\n","    print(f\"Các cột của DataFrame sau xử lý: {list(df_final.columns)}\")\n","\n","    # --- 4. Lưu Dữ Liệu Đã Xử Lý Ra File CSV Mới ---\n","    df_final.to_csv(output_file_path, index=False, encoding='utf-8')\n","\n","    print(f\"\\n✅ Đã hoàn tất! Dữ liệu JSON đã được chuyển sang CSV và lưu vào:\")\n","    print(f\"'{output_file_path}'\")\n","\n","except FileNotFoundError:\n","    print(f\"\\n❌ Lỗi: Không tìm thấy file tại đường dẫn '{input_file_path}'.\")\n","    print(\"Vui lòng kiểm tra lại đường 