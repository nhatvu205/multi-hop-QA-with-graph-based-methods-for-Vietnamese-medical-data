","    'DRUGCHEMICAL',    # Thuốc\n","    'MEDICALDEVICE'    # Thiết bị y tế\n","]\n","\n","# --- 2.2. Lọc dựa trên Logic (Phiên bản Điều chỉnh V2) ---\n","\n","def is_valid_relation_type_v2(head_type, tail_type, relation_type):\n","    \"\"\"Kiểm tra logic chặt chẽ cho các cặp type - relation trong y tế.\"\"\"\n","\n","    # Quy tắc 1: HAS_SYMPTOM phải hợp lý (Bệnh/Tình trạng -> Triệu chứng cụ thể)\n","    if relation_type == 'HAS_SYMPTOM':\n","\n","        # a. Subject (Đầu) nên là một Bệnh/Tình trạng/Bộ phận\n","        if head_type not in ['DISEASESYMTOM', 'CONDITION', 'BODYPART', 'ANATOMY']:\n","            # Ví dụ: Loại bỏ TÊ TAY (Triệu chứng) HAS_SYMPTOM BẨM SINH\n","            return False\n","\n","        # b. Object (Đuôi - Triệu chứng) không được là Bệnh, Chỉ số, Nguyên nhân, Phân loại, v.v.\n","        if tail_type in ENTITY_TYPES_NOT_SYMPTOMS:\n","            # Ví dụ: Loại bỏ VIÊM DA CƠ ĐỊA HAS_SYMPTOM HUYẾT ÁP (HUYẾT ÁP là BIOMARKER)\n","            # Ví dụ: Loại bỏ TĂNG HUYẾT ÁP HAS_SYMPTOM BỆNH LÝ (BỆNH LÝ là DISEASESYMTOM)\n","            return False\n","\n","    # Quy tắc 2: DIAGNOSED_BY phải là Bệnh DIAGNOSED_BY Phương pháp chẩn đoán\n","    if relation_type == 'DIAGNOSED_BY':\n","        if head_type not in ['DISEASESYMTOM', 'CONDITION'] or tail_type not in ['DIAGNOSTIC']:\n","            return False\n","\n","    # Quy tắc 3: TREATED_BY phải là Bệnh TREATED_BY Thuốc/Phương pháp\n","    if relation_type == 'TREATED_BY':\n","        if head_type not in ['DISEASESYMTOM', 'CONDITION'] or tail_type not in ['DRUGCHEMICAL', 'MEDDEVICETECHNIQUE', 'PREVENTIVEMED']:\n","            return False\n","\n","    return True\n","\n","df_filtered['is_valid_v2'] = df_filtered.apply(\n","    lambda row: is_valid_relation_type_v2(row['head_entity_type'], row['tail_entity_type'], row['relation_type']), axis=1\n",")\n","\n","df_final_filtered = df_filtered[df_filtered['is_valid_v2']].drop(\n","    columns=['is_valid', 'is_valid_v2'],\n","    errors='ignore' # THÊM tham số này để xử lý an toàn\n",")\n","\n","print(f\"\\n--- Thống kê Lọc nhiễu Logic Điều chỉnh (V2) ---\")\n","print(f\"Số quan hệ sau khi lọc Logic: {len(df_final_filtered)}\")\n","\n","## --- BƯỚC 3: Tinh chỉnh Cấu trúc (Structure Refinement) ---\n","\n","# 3.1. Loại bỏ các bản ghi trùng lặp\n","triple_cols = ['head_entity_text_canonical', 'relation_type', 'tail_entity_text_canonical']\n","\n","# Sắp xếp theo confidence giảm dần để giữ lại bản ghi có độ tin cậy cao nhất\n","df_final_filtered = df_final_filtered.sort_values(by='confidence', ascending=False)\n","\n","# Loại bỏ trùng lặp dựa trên 3 cột Triple\n","df_final = df_final_filtered.drop_duplicates(subset=triple_cols, keep='first')\n","\n","print(f\"Số quan hệ CUỐI CÙNG sau khi loại trùng lặp: {len(df_final)}\")\n","\n","print(\"\\n--- DataFrame Triple CHUẨN HÓA CUỐI CÙNG (5 dòng) ---\")\n","output_cols = ['head_entity_text_canonical', 'head_entity_type',\n","               'relation_type',\n","               'tail_entity_text_canonical', 'tail_entity_type',\n","               'confidence']\n","print(df_final[output_cols].head())\n","\n","# Xuất kết quả cuối cùng:\n","OUTPUT_CSV_PATH = '/content/drive/MyDrive/DO_AN_DS_KI_1_NAM_3/DS201/NLe/entity-canonicalization/RE-clean.csv'\n","df_final.to_csv(OUTPUT_CSV_PATH, index=False, encoding='utf-8-sig')\n","print(f\"\\n🎉 Đã xuất kết quả cuối cùng thành công tới: {OUTPUT_CSV_PATH}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"vv0u01V13QWG","executionInfo":{"status":"ok","timestamp":1765734731338,"user_tz":-420,"elapsed":1094,"user":{"displayName":"Như Lê","userId":"11114889294028253242"}},"outputId":"369d10c8-5fe2-420e-ea86-2931d8326cff"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","--- Thống kê Lọc nhiễu Logic Điều chỉnh (V2) ---\n","Số quan hệ sau khi lọc Logic: 14523\n","Số quan hệ CUỐI CÙNG sau khi loại trùng lặp: 14523\n","\n","--- DataFrame Triple CHUẨN HÓA CUỐI CÙNG (5 dòng) ---\n","     head