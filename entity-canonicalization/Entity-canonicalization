N CỦA BẠN\n","# *******************************************************************\n","\n","# --- BƯỚC 0: Trích xuất danh sách Thực thể Độc nhất ---\n","\n","# 1. Trích xuất tất cả các thực thể (head và tail)\n","all_entities = pd.concat([df['head_entity_text'], df['tail_entity_text']]).unique()\n","all_entities = pd.Series(all_entities).str.lower().str.strip().tolist()\n","\n","# Lọc bỏ các giá trị trống hoặc không có ý nghĩa\n","all_entities = [e for e in all_entities if e and len(e) > 1]\n","\n","print(f\"Tổng số thực thể độc nhất cần phân cụm: {len(all_entities)}\")\n","\n","# --- BƯỚC 1: Xây dựng Ma trận Tương đồng (Similarity Matrix) ---\n","\n","def calculate_similarity_matrix(entities):\n","    \"\"\"Tính toán ma trận tương đồng (0 đến 1) giữa tất cả các cặp thực thể.\"\"\"\n","    n = len(entities)\n","    similarity_matrix = np.zeros((n, n))\n","\n","    print(\"Đang tính toán ma trận tương đồng (có thể mất vài phút với dữ liệu lớn)...\")\n","\n","    for i in range(n):\n","        for j in range(i, n):\n","            # Dùng fuzz.ratio để tính độ tương đồng chuỗi (0-100)\n","            score = fuzz.ratio(entities[i], entities[j]) / 100.0\n","            similarity_matrix[i, j] = score\n","            similarity_matrix[j, i] = score\n","\n","    return similarity_matrix\n","\n","similarity_matrix = calculate_similarity_matrix(all_entities)\n","\n","# Ma trận Khoảng cách (Distance Matrix): Khoảng cách = 1 - Tương đồng\n","distance_matrix = 1 - similarity_matrix\n","\n","# --- BƯỚC 2: Áp dụng Phân cụm Ngang hàng (Agglomerative Clustering) ---\n","\n","SIMILARITY_THRESHOLD = 0.90\n","DISTANCE_THRESHOLD = 1 - SIMILARITY_THRESHOLD\n","MIN_CLUSTER_SIZE = 2\n","\n","print(f\"\\n--- Phân cụm với Ngưỡng tương đồng: {SIMILARITY_THRESHOLD * 100:.0f}% (Khoảng cách: {DISTANCE_THRESHOLD:.2f}) ---\")\n","\n","# Khởi tạo mô hình phân cụm\n","clustering = AgglomerativeClustering(\n","    n_clusters=None,\n","    distance_threshold=DISTANCE_THRESHOLD,\n","    metric='precomputed', # Thay affinity='precomputed' bằng metric='precomputed' theo phiên bản scikit-learn mới\n","    linkage='average'\n",")\n","\n","cluster_labels = clustering.fit_predict(distance_matrix)\n","\n","# Thêm nhãn cụm vào DataFrame kết quả\n","cluster_df = pd.DataFrame({\n","    'entity_text': all_entities,\n","    'cluster_label': cluster_labels\n","})\n","\n","# --- BƯỚC 3: Tạo Báo cáo Kết quả Phân cụm và Gợi ý Tên Chuẩn ---\n","\n","# Nhóm theo nhãn cụm và tạo báo cáo\n","clusters_report = cluster_df.groupby('cluster_label')['entity_text'].apply(list).reset_index()\n","\n","# Tạo DataFrame báo cáo cuối cùng để xuất file\n","final_report_list = []\n","cluster_id = 0\n","\n","for index, row in clusters_report.iterrows():\n","    entities = row['entity_text']\n","\n","    if len(entities) >= MIN_CLUSTER_SIZE:\n","        cluster_id += 1\n","\n","        # Gợi ý tên chuẩn: Chọn thực thể dài nhất (thường ít viết tắt hơn)\n","        suggested_canonical = max(entities, key=len)\n","\n","        # Thêm từng biến thể vào danh sách báo cáo\n","        for entity in entities:\n","            final_report_list.append({\n","                'Cluster_ID': cluster_id,\n","                'Entity_Variant': entity,\n","                'Suggested_Canonical_Name': suggested_canonical.upper(),\n","                'Num_Variants_in_Cluster': len(entities),\n","                'Similarity_Threshold': SIMILARITY_THRESHOLD\n","            })\n","\n","report_df = pd.DataFrame(final_report_list)\n","\n","print(\"\\n--- CÁC CỤM THỰC THỂ ĐƯỢC TẠO RA (Gợi ý cho canonical_map) ---\")\n","print(report_df[['Cluster_ID', 'Entity_Variant', 'Suggested_Canonical_Name']].head(10))\n","print(f\"\\nTổng số cụm được tạo (>= {MIN_CLUSTER_SIZE} thực thể): {cluster_id}\")\n","\n","# --- BƯỚC 4: Xuất file CSV kết quả ---\n","\n","OUTPUT_PATH = '/content/drive/MyDrive/DO_AN_DS_KI_1_NAM_3/DS201/NLe/entity-canonicalization/entity_canonicalization_suggestions.csv' # THAY ĐỔI ĐƯỜNG DẪN NÀY\n","\n","try:\n"," 