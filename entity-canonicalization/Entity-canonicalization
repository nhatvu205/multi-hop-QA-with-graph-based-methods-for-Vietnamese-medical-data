 Tên Chuẩn.\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","from fuzzywuzzy import fuzz\n","from fuzzywuzzy import process\n","import os # Import thêm thư viện os để kiểm tra sự tồn tại của file\n","\n","# *******************************************************************\n","# THAY ĐỔI ĐƯỜNG DẪN DƯỚI ĐÂY BẰNG ĐƯỜNG DẪN FILE CSV CỦA BẠN\n","# *******************************************************************\n","CANONICAL_MAP_FILE_PATH = '/content/drive/MyDrive/DO_AN_DS_KI_1_NAM_3/DS201/NLe/entity-canonicalization/entity_canonicalization_suggestions.csv'\n","\n","# 1.1. ĐỌC FILE CSV VÀ CHUYỂN THÀNH TỪ ĐIỂN canonical_map\n","canonical_map = {}\n","if os.path.exists(CANONICAL_MAP_FILE_PATH):\n","    print(f\"Đang đọc file Canonical Map từ: {CANONICAL_MAP_FILE_PATH}\")\n","    try:\n","        # Giả định file CSV có 2 cột: 'Entity_Variant' (Key) và 'Suggested_Canonical_Name' (Value)\n","        map_df = pd.read_csv(CANONICAL_MAP_FILE_PATH, encoding='utf-8-sig')\n","\n","        # Chọn 2 cột cần thiết và chuyển thành từ điển.\n","        # Cần đảm bảo các cột này tồn tại trong file CSV của bạn.\n","        canonical_map = pd.Series(\n","            map_df['Suggested_Canonical_Name'].values,\n","            index=map_df['Entity_Variant']\n","        ).to_dict()\n","\n","        print(f\"Đã tải {len(canonical_map)} ánh xạ chuẩn.\")\n","\n","    except KeyError:\n","        print(\"LỖI: Tên cột trong file CSV không khớp ('Entity_Variant' hoặc 'Suggested_Canonical_Name').\")\n","        print(\"Vui lòng kiểm tra lại cấu trúc file CSV.\")\n","    except Exception as e:\n","        print(f\"LỖI khi đọc file CSV: {e}\")\n","\n","else:\n","    print(f\"CẢNH BÁO: Không tìm thấy file tại đường dẫn: {CANONICAL_MAP_FILE_PATH}. Sử dụng từ điển rỗng.\")\n","\n","\n","## --- BƯỚC 1: Entity Canonicalization (Chuẩn hóa Thực thể) ---\n","\n","def canonicalize_entity(text, entity_type):\n","    \"\"\"\n","    Hàm chuẩn hóa thực thể bằng cách đối sánh chính xác và đối sánh mờ (Fuzzy Matching).\n","    \"\"\"\n","\n","    # Chuẩn hóa văn bản đầu vào để khớp với keys trong từ điển (đã được làm ở bước Phân cụm)\n","    text_lower = text.lower().strip()\n","\n","    # 1. Đối sánh chính xác (Ưu tiên)\n","    if text_lower in canonical_map:\n","        return canonical_map[text_lower]\n","\n","    # 2. Đối sánh Mờ (Fuzzy Matching) - Linking nhẹ\n","    # Chỉ áp dụng khi không tìm thấy chính xác và có thể cần tìm kiếm các biến thể mới.\n","    if canonical_map and entity_type in ['MEDDEVICETECHNIQUE', 'DRUGCHEMICAL', 'PREVENTIVEMED']:\n","\n","        # Lấy danh sách các tên chuẩn (Values) để tìm kiếm mờ\n","        choices = list(canonical_map.values())\n","        if choices:\n","            # Tìm đối sánh tốt nhất (điểm so sánh > 90%)\n","            # Lưu ý: fuzzywuzzy làm việc tốt nhất với chuỗi, text_lower được dùng để tìm\n","            best_match = process.extractOne(text_lower, choices, scorer=fuzz.ratio)\n","\n","            # Kiểm tra độ tin cậy của đối sánh mờ\n","            if best_match and best_match[1] >= 90:\n","                return best_match[0] # Trả về tên chuẩn\n","\n","    return text # Giữ nguyên nếu không tìm thấy đối sánh phù hợp\n","\n","# Áp dụng hàm chuẩn hóa cho head_entity_text và tail_entity_text\n","df['head_entity_text_canonical'] = df.apply(\n","    lambda row: canonicalize_entity(row['head_entity_text'], row['head_entity_type']), axis=1\n",")\n","\n","df['tail_entity_text_canonical'] = df.apply(\n","    lambda row: canonicalize_entity(row['tail_entity_text'], row['tail_entity_type']), axis=1\n",")\n","\n","print(\"--- DataFrame sau khi Chuẩn hóa Thực thể ---\")\n","print(df[['head_entity_text', 'head_entity_text_canonical', 'tail_entity_text', 'tail_entity_text_canonical']].head())\n","\n","## --- BƯỚC 2 & 3: Lọc nhiễu và Tinh chỉnh Cấu trúc ---\n","\n","# 2.1. Lọc dựa trên Độ tin cậy (Confidence Threshold)\n","CONFIDENCE_THRESHOLD = 0.9995  # Điều chỉnh ngưỡng này cho phù hợp\n","\n","df_filtered = df[df['confidence'] >= CONFIDENCE_THRESHOLD].copy()\n","\n","print(f\"\\n--- Thống kê Lọc nhiễu (Ngưỡng: {CONFIDENCE_THRESHOLD}) ---\")\n","print(f\"Tổng số quan hệ ban đầu: {len(df)}\")\n","print(f\"Số quan hệ sau khi lọc Confidence: {len(df_filtered)}\")\n","\n","# 2.2. Lọc dựa trên Logic (Tùy chọn)\n","def is_valid_relation_type(head_type, tail_type, relation_type):\n","    \"\"\"Kiểm tra logic cơ bản cho các cặp type - relation\"\"\"\n","    if relation_type == 'DIAGNOSED_BY' and head_type not in ['DISEASESYMTOM', 'CONDITION']:\n","        return False\n","    # Thêm các quy tắc logic khác của bạn tại đây...\n","    return True\n","\n","df_filtered['is_valid'] = df_filtered.apply(\n","    lambda row: is_valid_relation_type(row['head_entity_type'], row['tail_entity_type'], row['relation_type']), axis=1\n",")\n","\n","df_filtered = df_filtered[df_filtered['is_valid']].drop(columns=['is_valid'])\n","\n","print(f\"Số quan hệ sau khi lọc Logic: {len(df_filtered)}\")\n","\n","## --- BƯỚC 3: Tinh chỉnh Cấu trúc (Structure Refinement) ---\n","\n","# 3.1. Loại bỏ các bản ghi trùng lặp\n","triple_cols = ['head_entity_text_canonical', 'relation_type', 'tail_entity_text_canonical']\n","\n","df_filtered = df_filtered.sort_values(by='confidence', ascending=False)\n","\n","df_final = df_filtered.drop_duplicates(subset=triple_cols, keep='first')\n","\n","print(f\"Số quan hệ CUỐI CÙNG sau khi loại trùng lặp: {len(df_final)}\")\n","\n","print(\"\\n--- DataFrame Triple CHUẨN HÓA CUỐI CÙNG (5 dòng) ---\")\n","output_cols = ['head_entity_text_canonical', 'head_entity_type',\n","               'relation_type',\n","               'tail_entity_text_canonical', 'tail_entity_type',\n","               'confidence']\n","print(df_final[output_cols].head())\n","\n","# Xuất kết quả cuối cùng:\n","df_final.to_csv('/content/drive/MyDrive/DO_AN_DS_KI_1_NAM_3/DS201/NLe/entity-canonicalization/final_canonicalized_triples.csv', index=False, encoding='utf-8-sig')"],"metadata":{"colab":{"base_uri":"http