ering\n","from sklearn.metrics import pairwise_distances\n","\n","# --- BƯỚC 0: Trích xuất danh sách Thực thể Độc nhất ---\n","\n","# 1. Trích xuất tất cả các thực thể (head và tail)\n","all_entities = pd.concat([df['head_entity_text'], df['tail_entity_text']]).unique()\n","all_entities = pd.Series(all_entities).str.lower().str.strip().tolist()\n","\n","# Lọc bỏ các giá trị trống hoặc không có ý nghĩa\n","all_entities = [e for e in all_entities if e and len(e) > 1]\n","\n","print(f\"Tổng số thực thể độc nhất cần phân cụm: {len(all_entities)}\")\n","\n","# --- BƯỚC 1: Xây dựng Ma trận Tương đồng (Similarity Matrix) ---\n","\n","def calculate_similarity_matrix(entities):\n","    \"\"\"Tính toán ma trận tương đồng (0 đến 1) giữa tất cả các cặp thực thể.\"\"\"\n","    n = len(entities)\n","    # Khởi tạo ma trận tương đồng\n","    similarity_matrix = np.zeros((n, n))\n","\n","    print(\"Đang tính toán ma trận tương đồng (có thể mất vài phút với dữ liệu lớn)...\")\n","\n","    # Điền vào ma trận tương đồng bằng điểm Fuzzy Ratio\n","    for i in range(n):\n","        for j in range(i, n):\n","            # Dùng fuzz.ratio để tính độ tương đồng chuỗi (0-100)\n","            score = fuzz.ratio(entities[i], entities[j]) / 100.0\n","            similarity_matrix[i, j] = score\n","            similarity_matrix[j, i] = score\n","\n","    return similarity_matrix\n","\n","similarity_matrix = calculate_similarity_matrix(all_entities)\n","\n","# Ma trận Khoảng cách (Distance Matrix): Khoảng cách = 1 - Tương đồng\n","# Thuật toán phân cụm Agglomerative Clustering dùng ma trận khoảng cách\n","distance_matrix = 1 - similarity_matrix\n","\n","# --- BƯỚC 2: Áp dụng Phân cụm Ngang hàng (Agglomerative Clustering) ---\n","\n","# THRESHOLD (Ngưỡng): Mức độ tương đồng tối thiểu để gộp hai thực thể vào cùng một cụm.\n","# distance_threshold = 1 - (Similarity_Score / 100)\n","# Ví dụ: Nếu muốn độ tương đồng tối thiểu là 90%, thì ngưỡng khoảng cách là 1 - 0.9 = 0.1\n","SIMILARITY_THRESHOLD = 0.90\n","DISTANCE_THRESHOLD = 1 - SIMILARITY_THRESHOLD\n","MIN_CLUSTER_SIZE = 2 # Chỉ quan tâm các cụm có từ 2 thực thể trở lên\n","\n","print(f\"\\n--- Phân cụm với Ngưỡng tương đồng: {SIMILARITY_THRESHOLD * 100:.0f}% (Khoảng cách: {DISTANCE_THRESHOLD:.2f}) ---\")\n","\n","# Khởi tạo mô hình phân cụm\n","# metric='precomputed' vì chúng ta đã tính distance_matrix\n","# linkage='average' thường hoạt động tốt cho việc tìm các cụm đồng nhất\n","clustering = AgglomerativeClustering(\n","    n_clusters=None,\n","    distance_threshold=DISTANCE_THRESHOLD,\n","    metric='precomputed',\n","    linkage='average'\n",")\n","\n","# Chạy phân cụm\n","# distance_matrix được truyền dưới dạng X\n","cluster_labels = clustering.fit_predict(distance_matrix)\n","\n","# Thêm nhãn cụm vào DataFrame kết quả\n","cluster_df = pd.DataFrame({\n","    'entity_text': all_entities,\n","    'cluster_label': cluster_labels\n","})\n","\n","# --- BƯỚC 3: Tạo Báo cáo Kết quả Phân cụm và Gợi ý Tên Chuẩn ---\n","\n","# Nhóm theo nhãn cụm và tạo báo cáo\n","clusters_report = cluster_df.groupby('cluster_label')['entity_text'].apply(list).reset_index()\n","\n","print(\"\\n--- CÁC CỤM THỰC THỂ GẦN GIỐNG NHAU (Gợi ý cho canonical_map) ---\")\n","print(\"Hãy xem xét các cụm sau và chọn 1 tên chuẩn cho mỗi cụm có nhiều hơn 1 thực thể.\")\n","print(\"-\" * 70)\n","\n","suggestion_map = {}\n","cluster_id = 0\n","\n","for index, row in clusters_report.iterrows():\n","    entities = row['entity_text']\n","\n","    # Chỉ hiển thị các cụm có từ MIN_CLUSTER_SIZE trở lên\n","    if len(entities) >= MIN_CLUSTER_SIZE:\n","        cluster_id += 1\n","\n","        # Gợi ý tên chuẩn: Chọn thực thể phổ biến nhất hoặc dài nhất\n","        # Ở đây ta chọn thực thể đầu tiên (hoặc phổ biến nhất nếu bạn có cột đếm)\n","        suggested_canonical = max(entities, key=len)\n","\n","        print(f\"Cụm #{cluster_id} ({len(entities)} biến thể):\")\n","        print(f\"  Biến thể: {', '.join(entities)}\")\n","        print(f\"  Gợi ý Tên Chuẩn: **{suggested_canonical.upper()}**\")\n","        print(\"-\" * 70)\n","\n","        # Thêm vào từ điển gợi ý để bạn có thể sao chép/dán\n","        for entity in entities:\n","            suggestion_map[entity] = suggested_canonical.upper()\n","\n","print(\"\\n--- Từ điển Gợi ý Tự động (Để Sao chép và Tinh chỉnh) ---\")\n","# In ra từ điển gợi ý, bạn có thể copy và tinh chỉnh nó thành canonical_map\n","for key, value in suggestion_map.items():\n","    print(f\"'{key}': '{value}',\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"P7mlabUyg4fg","executionInfo":{"status":"ok","timestamp":1765727738734,"user_tz":-420,"elapsed":74725,"user":{"displayName":"Như Lê","userId":"11114889294028253242"}},"outputId":"c9b0013c-55bd-49f4-9f76-23e4ad0e990b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Tổng số thực thể độc nhất cần phân cụm: 6815\n","Đang tính toán ma trận tương đồng (có thể mất vài phút với dữ liệu lớn)...\n","\n","--- Phân cụm với Ngưỡng tương đồng: 90% (Khoảng cách: 0.10) ---\n","\n","--- CÁC CỤM THỰC THỂ GẦN GIỐNG NHAU (Gợi ý cho canonical_map) ---\n","Hãy xem xét các cụm sau và chọn 1 tên chuẩn cho mỗi cụm có nhiều hơn 1 thực thể.\n","----------------------------------------------------------------------\n","Cụm #1 (5 biến thể):\n","  Biến thể: bệnh vảy nến, bệnh vẩy nến, bệnh vảy nến, bệnh vẩy nến, ệnh vẩy nến\n","  Gợi ý Tên Chuẩn: **BỆNH VẢY NẾN**\n","----------------------------------------------------------------------\n","Cụm #2 (4 biến thể):\n","  Biến thể: phẫu thuật cắt, phẫu thuật cắt eo, phẫu thuật cắt v, phẫu thuật cắt\n","  Gợi ý Tên Chuẩn: **PHẪU THUẬT CẮT EO**\n","----------------------------------------------------------------------\n","Cụm #3 (3 biến thể):\n","  Biến thể: rối loạn vận động, ối loạn vận động, rối loạn vận động tử\n","  Gợi ý Tên Chuẩn: **RỐI LOẠN VẬN ĐỘNG TỬ**\n","----------------------------------------------------------------------\n","Cụm #4 (3 biến thể