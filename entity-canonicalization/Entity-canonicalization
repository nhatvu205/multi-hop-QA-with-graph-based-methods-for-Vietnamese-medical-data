trên danh sách Whitelist (các Schema hợp lý).\n","    \"\"\"\n","    schema_tuple = (head_type, relation_type, tail_type)\n","    return schema_tuple in VALID_SCHEMA_SET\n","\n","# --- 3. ĐỌC VÀ LỌC DỮ LIỆU ---\n","try:\n","    # Đọc file CSV\n","    df = pd.read_csv(INPUT_FILE_PATH, encoding='utf-8-sig')\n","    print(f\"Đã tải DataFrame ban đầu thành công. Số lượng Triple: {len(df)}\")\n","except Exception as e:\n","    print(f\"LỖI: Không thể đọc file CSV tại {INPUT_FILE_PATH}. Lỗi chi tiết: {e}\")\n","    exit()\n","\n","# Giả định df này đã chứa các cột cần thiết sau khi canonicalization:\n","# 'head_entity_type', 'relation_type', 'tail_entity_type'\n","\n","# 4. ÁP DỤNG LỌC LOGIC WHITELIST\n","df['is_valid_whitelist'] = df.apply(\n","    lambda row: is_valid_relation_type_whitelist(\n","        row['head_entity_type'],\n","        row['relation_type'],\n","        row['tail_entity_type']\n","    ),\n","    axis=1\n",")\n","\n","# Lọc các Triple hợp lý\n","df_logic_filtered = df[df['is_valid_whitelist']].copy()\n","\n","print(f\"Số lượng Triple sau khi lọc Logic (Whitelist): {len(df_logic_filtered)}\")\n","\n","# 5. TINH CHỈNH CUỐI CÙNG (Loại bỏ trùng lặp nếu cần)\n","# Giả định: File đầu vào đã được loại trùng lặp trước đó.\n","# Tuy nhiên, ta vẫn nên loại bỏ cột phụ trước khi lưu.\n","df_final = df_logic_filtered.drop(columns=['is_valid_whitelist'])\n","\n","# 6. LƯU FILE KẾT QUẢ\n","try:\n","    df_final.to_csv(OUTPUT_FILE_PATH, index=False, encoding='utf-8-sig')\n","    print(f\"\\n🎉 Đã xuất file CSV đã lọc Logic thành công tới: {OUTPUT_FILE_PATH}\")\n","except Exception as e:\n","    print(f\"LỖI khi xuất file CSV: {e}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"33xFR5VxOOeA","executionInfo":{"status":"ok","timestamp":1765906924427,"user_tz":-420,"elapsed":4941,"user":{"displayName":"Lê Diễm Quỳnh Như","userId":"00218023577505911477"}},"outputId":"e882fadf-0a75-429e-c7bc-e09db440dd16"},"execution_count":3,"outputs":[{"output_type"